# Environment variables for ValuAI

# ── Data Sources ──────────────────────────────────────────────────────────────
DATA_PRIMARY_ADAPTER=yfinance
DATA_FMP_API_KEY=
DATA_ALPHA_VANTAGE_API_KEY=
DATA_POLYGON_API_KEY=
DATA_FRED_API_KEY=
DATA_CACHE_TTL_SECONDS=3600
DATA_HISTORICAL_YEARS=10

# ── ML Settings ───────────────────────────────────────────────────────────────
ML_CV_FOLDS=5
ML_OPTUNA_TRIALS=50
ML_RANDOM_SEED=42
ML_ENABLE_LSTM=false
ML_ENABLE_CATBOOST=true
ML_ENABLE_LIGHTGBM=true
ML_ENABLE_XGBOOST=true
ML_N_JOBS=-1

# ── Simulation ────────────────────────────────────────────────────────────────
SIM_N_SIMULATIONS=10000
SIM_RANDOM_SEED=42

# ── DCF Defaults ──────────────────────────────────────────────────────────────
DCF_DEFAULT_FORECAST_YEARS=10
DCF_DEFAULT_TERMINAL_GROWTH_RATE=0.025
DCF_DEFAULT_MARGIN_OF_SAFETY=0.30
DCF_RISK_FREE_RATE=0.0445
DCF_MARKET_RISK_PREMIUM=0.055

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=postgresql://postgres:password@localhost:5432/valuation_db
DB_REDIS_URL=redis://localhost:6379/0

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
